//Add this into it

#!/bin/bash

# Configuration
ANIM_DIR="$HOME/.config/niri/animations"
CURRENT_LINK="$ANIM_DIR/current_animation.kdl"

# 1. Get all .kdl files (excluding the symlink itself)
mapfile -t FILES < <(ls "$ANIM_DIR"/*.kdl | grep -v "current_animation.kdl" | sort)

# Check if the directory is empty
if [ ${#FILES[@]} -eq 0 ]; then
    notify-send "Niri Error" "No animation files found in $ANIM_DIR"
    exit 1
fi

# 2. Identify the currently active animation
CURRENT_TARGET=$(readlink -f "$CURRENT_LINK")

NEXT_INDEX=0
for i in "${!FILES[@]}"; do
   if [[ "${FILES[$i]}" == "$CURRENT_TARGET" ]]; then
       # Calculate the next index (loop back to 0 at the end)
       NEXT_INDEX=$(( (i + 1) % ${#FILES[@]} ))
       break
   fi
done

# 3. Update the symbolic link
NEW_ANIM="${FILES[$NEXT_INDEX]}"
rm -f "$CURRENT_LINK"
ln -s "$NEW_ANIM" "$CURRENT_LINK"

# 4. Notify the user
ANIM_NAME=$(basename "$NEW_ANIM" .kdl)
# Capitalize first letter
DISPLAY_NAME="${ANIM_NAME^}"

# Use -r 101 to replace the existing notification (cleaner toggle)
notify-send -a "Niri Switcher" -r 101 "Niri Visuals" "Now using: $DISPLAY_NAME" -i "video-display" -t 1500


//Save and exit

//Make it executable

sudo chmod +x ~/.local/bin/niri-anim-toggle.sh

//edit your niri config.kdl, remove the animation section and add in its place

include "animations/current_animation.kdl"

